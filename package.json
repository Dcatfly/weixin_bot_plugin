{
  "name": "weixin-bot-plugin",
  "version": "0.1.0",
  "description": "WeChat Bot SDK via iLink Bot API",
  "license": "MIT",
  "author": "zhzhang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dcatfly/weixin_bot_plugin.git"
  },
  "keywords": [
    "wechat",
    "weixin",
    "bot",
    "sdk"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "dependencies": {
    "qrcode-terminal": "0.12.0",
    "silk-wasm": "^3.7.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^4.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
